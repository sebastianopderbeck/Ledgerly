{
  "name": "ledgerly",
  "private": true,
  "type": "module",
  "workspaces": ["shared", "server", "client"],
  "trustedDependencies": ["esbuild", "mongodb-memory-server"],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "bun run --filter '@ledgerly/client' dev",
    "dev": "concurrently -n server,client -c blue,green \"bun run dev:server\" \"bun run dev:client\"",
    "seed": "tsx server/src/rules/seedRules.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0"
  }
}
